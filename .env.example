# AI re-scoring is intentionally disabled until explicitly enabled.
PRIORITY_RESCORE_ENABLED=0
PRIORITY_MODEL=gemini-3.1-flash-lite
PRIORITY_MAX_RUNS_PER_MINUTE=6
PRIORITY_MAX_RUNS_PER_DAY=24
PRIORITY_MAX_TOKENS_PER_DAY=100000

# Set one key locally. Never commit a populated .env file.
GEMINI_API_KEY=

# Local server defaults.
PRIORITY_HOST=127.0.0.1
PRIORITY_PORT=8780

